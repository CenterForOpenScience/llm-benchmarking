    # Prepare samples for tests: treat==1 (OS) vs treat==2 (TS)
    os_sample = df.loc[df['treat'] == 1, 'effort_t1'].dropna()
    ts_sample = df.loc[df['treat'] == 2, 'effort_t1'].dropna()


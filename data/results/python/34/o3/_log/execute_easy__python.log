import pandas as pd
import numpy as np
import statsmodels.formula.api as smf

DATA_PATH = '/app/data/original/34/input/replication_data/sandra_replicate.csv'

# Load data
df = pd.read_csv(DATA_PATH)

# Keep only accurate trials as in original analysis
accurate = df[df['accuracy'] == 1].copy()

# Standardize (z-score) variables matching original R code
accurate['logRT_z'] = (accurate['logRT'] - accurate['logRT'].mean()) / accurate['logRT'].std(ddof=0)
accurate['NFC_z'] = (accurate['NFC'] - accurate['NFC'].mean()) / accurate['NFC'].std(ddof=0)

# Mixed-effects linear regression with random intercept for SubjectID
formula = 'logRT_z ~ NFC_z * trial * rewardlevel + blocknumber'
model = smf.mixedlm(formula, accurate,
                    groups=accurate['SubjectID'])
result = model.fit(method='lbfgs')

print(result.summary())

# Extract focal 3-way interaction term
term = 'NFC_z:trial:rewardlevel'
if term in result.params.index:
    coef = result.params[term]
    pval = result.pvalues[term]
    print(f'Focal 3-way interaction coefficient: {coef:.4f}, p-value: {pval:.4g}')
else:
    print('Focal interaction term not found in model parameters.')

# Save results to file
output_path = '/app/data/replication_results.txt'
with open(output_path, 'w') as f:
    f.write(result.summary().as_text())
    if term in result.params.index:
        f.write(f"\nFocal 3-way interaction coefficient: {coef:.4f}, p-value: {pval:.4g}\n")

print(f'Results written to {output_path}')


Action: write_file({"file_path":"data/original/34/input/replication_data/analysis__py.py","file_content":"\"\"\"\nReplication analysis translated to Python.\nReads /app/data/sandra_replicate.csv, fits linear mixed-effects model for logRT\nanalogous to lmer(scale(logRT) ~ scale(NFC) * trial * rewardlevel + blocknumber + (1|SubjectID))\nSaves summary to /app/data/replication_results.txt\n\"\"\"\nimport pandas as pd\nimport numpy as np\nimport statsmodels.api as sm\nfrom statsmodels.formula.api import mixedlm\nfrom sklearn.preprocessing import StandardScaler\n\n# Path to data (assumed mounted at /app/data)\nDATA_PATH = '/app/data/sandra_replicate.csv'\nOUTPUT_PATH = '/app/data/replication_results.txt'\n\ndef main():\n    # Read data\n    df = pd.read_csv(DATA_PATH)\n\n    # Filter to correct trials as in original (accuracy == 1)\n    df = df[df['accuracy'] == 1].copy()\n\n    # Drop rows with missing key variables\n    df = df.dropna(subset=['logRT', 'NFC', 'trial', 'rewardlevel', 'blocknumber', 'SubjectID'])\n\n    # Scale logRT and NFC\n    scaler = StandardScaler()\n    df['scale_logRT'] = scaler.fit_transform(df[['logRT']])\n    df['scale_NFC'] = scaler.fit_transform(df[['NFC']])\n\n    # Fit linear mixed model with random intercept for SubjectID\n    # Formula: scale_logRT ~ scale_NFC * trial * rewardlevel + blocknumber\n    formula = 'scale_logRT ~ scale_NFC * trial * rewardlevel + blocknumber'\n\n    # MixedLM requires groups; specify random intercept\n    md = mixedlm(formula, df, groups=df['SubjectID'])\n    try:\n        mdf = md.fit(reml=False)\n    except Exception as e:\n        # Try different starting params or method\n        mdf = md.fit(method='nm', maxiter=200, full_output=True)\n\n    # Save summary\n    with open(OUTPUT_PATH, 'w') as f:\n        f.write(mdf.summary().as_text())\n\n    # Also extract the three-way interaction coefficient if present\n    params = mdf.params\n    pvalues = mdf.pvalues\n    interaction_name = 'scale_NFC:trial:rewardlevel'\n    with open(OUTPUT_PATH, 'a') as f:\n        f.write('\\n\\nExtracted statistics:\\n')\n        if interaction_name in params.index:\n            coef = params[interaction_name]\n            pval = pvalues[interaction_name]\n            f.write(f'Interaction {interaction_name}: coef={coef}, p={pval}\\n')\n        else:\n            f.write(f'Interaction {interaction_name} not found in model parameters.\\n')\n\nif __name__ == \"__main__\":\n    main()\n","overwrite":false})  

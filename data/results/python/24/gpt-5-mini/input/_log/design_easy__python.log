Action: functions.write_file({"file_path":"data/original/24/input/replication_data/analysis__py.py","file_content":"#!/usr/bin/env python3\nimport pandas as pd\nimport numpy as np\nfrom scipy import stats\nimport json\nimport os\n\nDATA_PATH = \"/app/data/original/24/input/replication_data/analysis-data.csv\"\nOUT_DIR = \"/app/data/original/24/input/replication_data\"\n\n# Load the processed analysis CSV (assumed to be precomputed as in the provided dataset)\ndf = pd.read_csv(DATA_PATH, dtype={\"subject\":str, \"condition\":str})\n\n# Filter to Test phase\nif 'phase' in df.columns:\n    test = df[df['phase'] == 'Test'].copy()\nelse:\n    raise RuntimeError('Expected column \"phase\" not found in data')\n\n# Normalize boolean-like columns if necessary\nfor col in ['correct', 'correct_1d_a', 'correct_1d_b']:\n    if col in test.columns:\n        if test[col].dtype == object:\n            test[col] = test[col].map({'TRUE': True, 'True': True, 'FALSE': False, 'False': False}).fillna(test[col])\n        test[col] = test[col].astype(bool)\n    else:\n        raise RuntimeError(f'Expected column \"{col}\" not found in data')\n\n# Compute per-subject accuracy summaries at test\ngroup = test.groupby(['subject', 'condition']).agg(\n    acc_2d=('correct', 'mean'),\n    acc_1d_a=('correct_1d_a', 'mean'),\n    acc_1d_b=('correct_1d_b', 'mean')\n).reset_index()\n\ngroup['acc_1d'] = group[['acc_1d_a', 'acc_1d_b']].max(axis=1)\n\n# Condition-level summaries\ncond_summary = group.groupby('condition').agg(M=('acc_1d', 'mean'), SD=('acc_1d', 'std'), N=('acc_1d', 'count')).reset_index()\n\n# Independent-samples t-test (equal variances) on acc_1d between conditions\ncontingent = group[group['condition'] == 'contingent']['acc_1d']\nfull = group[group['condition'] == 'full-information']['acc_1d']\n\nif len(contingent) == 0 or len(full) == 0:\n    raise RuntimeError('One of the conditions has zero subjects; cannot perform t-test')\n\ntstat, pval = stats.ttest_ind(contingent, full, equal_var=True)\n\n# Cohen's d as in the original R script: (M1 - M2) / sqrt((SD1^2 + SD2^2)/2)\nif cond_summary.shape[0] != 2:\n    # Attempt to align by condition names\n    try:\n        sd_cont = cond_summary.loc[cond_summary['condition'] == 'contingent', 'SD'].values[0]\n        sd_full = cond_summary.loc[cond_summary['condition'] == 'full-information', 'SD'].values[0]\n        m_cont = cond_summary.loc[cond_summary['condition'] == 'contingent', 'M'].values[0]\n        m_full = cond_summary.loc[cond_summary['condition'] == 'full-information', 'M'].values[0]\n    except Exception:\n        raise RuntimeError('Unexpected condition labels or counts in cond_summary')\nelse:\n    m_cont = cond_summary['M'].iloc[0]\n    m_full = cond_summary['M'].iloc[1]\n    sd_cont = cond_summary['SD'].iloc[0]\n    sd_full = cond_summary['SD'].iloc[1]\n\nsd_pooled = np.sqrt((sd_cont ** 2 + sd_full ** 2) / 2.0)\ncohens_d = (m_cont - m_full) / sd_pooled if sd_pooled != 0 else np.nan\n\nresults = {\n    'condition_summary': cond_summary.to_dict(orient='records'),\n    't_test': {\n        't_stat': float(tstat),\n        'p_value': float(pval),\n        'n_contingent': int(len(contingent)),\n        'n_full': int(len(full))\n    },\n    'cohen_d': float(cohens_d)\n}\n\n# Save results\nos.makedirs(OUT_DIR, exist_ok=True)\nwith open(os.path.join(OUT_DIR, 'replication_results.json'), 'w') as f:\n    json.dump(results, f, indent=2)\n\n# Print to stdout for quick inspection\nprint(json.dumps(results, indent=2))\n","overwrite":false}) 

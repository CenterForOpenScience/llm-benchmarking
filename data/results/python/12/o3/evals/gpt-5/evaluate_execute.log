import pandas as pd
import statsmodels.formula.api as smf
import statsmodels.api as sm
import os

# All IO must reference /app/data according to platform policy
BASE = "/app/data/original/12/0203_o3/replication_data"
DATA_PATH = os.path.join(BASE, "analysis_data.dta")

# Load dataset (pyreadstat via pandas)
df = pd.read_stata(DATA_PATH)

# Helper function to run model and return summary table for key variables
def run_ols_cluster(data, outcome, cluster_var="vill_id"):
    formula = f"{outcome} ~ literate_hh + land_owned + locaste_land_v + C(stcode)*C(caste)"
    model = smf.ols(formula=formula, data=data).fit(cov_type="cluster", cov_kwds={"groups": data[cluster_var]})
    return model

results = {}

# Main preregistered model: raw_inc_per_acre on full sample
model_raw_full = run_ols_cluster(df, "raw_inc_per_acre")
results["raw_full"] = model_raw_full

# Exploratory: net_inc_per_acre on full sample
model_net_full = run_ols_cluster(df, "net_inc_per_acre")
results["net_full"] = model_net_full

# Alternative subset: only states UP/B (codes 2 and 15)
subset = df[df["stcode"].isin([2, 15])]
model_raw_subset = run_ols_cluster(subset, "raw_inc_per_acre")
results["raw_subset_upb"] = model_raw_subset

# Save concise results focusing on key independent variable
out_lines = []
for name, mod in results.items():
    coef = mod.params.get("locaste_land_v", float("nan"))
    se = mod.bse.get("locaste_land_v", float("nan"))
    pval = mod.pvalues.get("locaste_land_v", float("nan"))
    out_lines.append(f"Model: {name}\n  Coef locaste_land_v: {coef:.4f}\n  SE: {se:.4f}\n  p-value: {pval:.4g}\n  N: {int(mod.nobs)}\n  R-squared: {mod.rsquared:.4f}\n\n")

RESULT_PATH = "/app/data/replication_results.txt"
with open(RESULT_PATH, "w") as f:
    f.writelines(out_lines)

# Also print to stdout for interactive use
print("".join(out_lines))


Action: functions.write_file({"file_path":"data/original/29/input/replication_data/analysis__py.py","file_content":"import os\nimport json\nimport numpy as np\nimport pandas as pd\nimport statsmodels.api as sm\n\n# Try to read dataset from /app/data first, fallback to original path\npossible_paths = [\"/app/data/SCORE_ALL_DATA.csv\",\"data/original/29/input/replication_data/SCORE_ALL_DATA.csv\"]\nfor p in possible_paths:\n    if os.path.exists(p):\n        data_path = p\n        break\nelse:\n    raise FileNotFoundError(f\"Could not find SCORE_ALL_DATA.csv in known locations: {possible_paths}\")\n\nprint(f\"Loading data from {data_path}\")\n\ndf = pd.read_csv(data_path)\n\n# Coerce Exclusion to numeric where possible and filter to included cases (0)\nif 'Exclusion' in df.columns:\n    try:\n        df['Exclusion_num'] = pd.to_numeric(df['Exclusion'], errors='coerce')\n    except Exception:\n        df['Exclusion_num'] = df['Exclusion']\n    df_in = df[df['Exclusion_num'] == 0].copy()\nelse:\n    df_in = df.copy()\n\n# Create average desirability measure as mean of S1_likely, S1_quality, S1_purchase\nfor col in ['S1_likely','S1_quality','S1_purchase']:\n    if col not in df_in.columns:\n        raise KeyError(f\"Expected column {col} in data but not found\")\n\ndf_in['average'] = df_in[['S1_likely','S1_quality','S1_purchase']].mean(axis=1)\n\n# Create contrast-coded predictors based on TYPE (e.g., ClB, ClU, CoB, CoU)\nif 'TYPE' not in df_in.columns:\n    raise KeyError(\"Expected column 'TYPE' in data but not found\")\n\ndef code_clarity(x):\n    try:\n        s = str(x)\n        return 1 if s.startswith('Cl') or 'Cl' in s else -1\n    except:\n        return np.nan\n\ndef code_experimental(x):\n    try:\n        s = str(x)\n        return 1 if 'B' in s else -1\n    except:\n        return np.nan\n\ndf_in['clarity'] = df_in['TYPE'].apply(code_clarity)\ndf_in['experimental'] = df_in['TYPE'].apply(code_experimental)\n\n# Interaction term\ndf_in['interaction'] = df_in['clarity'] * df_in['experimental']\n\n# Drop rows with missing predictors or outcome\nmodel_df = df_in[['average','clarity','experimental','interaction']].dropna()\n\n# Fit OLS regression: average ~ clarity + experimental + interaction\nX = sm.add_constant(model_df[['clarity','experimental','interaction']])\ny = model_df['average']\nmodel = sm.OLS(y, X).fit()\n\nresults = {\n    'n_obs': int(model.nobs),\n    'params': model.params.to_dict(),\n    'bse': model.bse.to_dict(),\n    'tvalues': model.tvalues.to_dict(),\n    'pvalues': model.pvalues.to_dict(),\n    'rsquared': model.rsquared,\n    'summary': model.summary().as_text()\n}\n\n# Write results to /app/data/replication_results.json (and fallback to local path)\nout_path = '/app/data/replication_results.json'\nlocal_out = 'data/original/29/input/replication_data/replication_results.json'\ntry:\n    with open(out_path, 'w') as f:\n        json.dump(results, f, indent=2)\n    print(f\"Wrote results to {out_path}\")\nexcept Exception:\n    with open(local_out, 'w') as f:\n        json.dump(results, f, indent=2)\n    print(f\"Wrote results to {local_out}\")\n\n# Also print the interaction coefficient and test info\nif 'interaction' in model.params:\n    inter = {\n        'coef': float(model.params['interaction']),\n        'se': float(model.bse['interaction']),\n        't': float(model.tvalues['interaction']),\n        'p': float(model.pvalues['interaction'])\n    }\n    print(\"Interaction result:\", inter)\nelse:\n    print(\"No 'interaction' term found in model results\")\n"} ) 

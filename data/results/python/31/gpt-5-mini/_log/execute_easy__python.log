Action: functions.write_file({
  "file_path": "data/original/31/input/replicate_experiment1__py.py",
  "file_content": "import json\nimport sys\nimport numpy as np\nimport pandas as pd\nfrom scipy import optimize, stats\nimport pyreadstat\n\nDATA_PATH = \"/app/data/original/31/input/replication_data/REPExperiment1Data.dta\"\nOUTPUT_PATH = \"/app/data/replication_results_experiment1.json\"\nB_BOOT = 200\nRANDOM_SEED = 0\n\ndef load_data(path):\n    try:\n        df, meta = pyreadstat.read_dta(path)\n    except Exception as e:\n        print(f\"ERROR reading data: {e}\")\n        raise\n    return df\n\n\ndef prepare_data(df):\n    # Expected variable names\n    expected = ['asian', 'lndiscratelo', 'lndiscratehi', 'givenprimingquestionnaire', 'largestakes', 'longterm', 'largelong', 'id']\n    missing = [v for v in expected if v not in df.columns]\n    if missing:\n        print(\"WARNING: Missing expected vars:\", missing)\n    df = df.copy()\n    # Drop rows with missing lower bound\n    df = df[~df['lndiscratelo'].isna()]\n    # Subset to asian == 1\n    df = df[df['asian'] == 1]\n    # Drop rows with missing covariates\n    covs = ['givenprimingquestionnaire', 'largestakes', 'longterm', 'largelong']\n    df = df.dropna(subset=covs)\n    # Create design matrix\n    X = pd.DataFrame({'intercept': 1}, index=df.index)\n    X['givenprimingquestionnaire'] = df['givenprimingquestionnaire']\n    X['largestakes'] = df['largestakes']\n    X['longterm'] = df['longterm']\n    X['largelong'] = df['largelong']\n    y_lo = df['lndiscratelo'].values\n    y_hi = df['lndiscratehi'].values\n    ids = df['id'].values\n    return df, X.values, y_lo, y_hi, ids\n\n\ndef neg_loglik(theta, X, y_lo, y_hi):\n    k = X.shape[1]\n    beta = theta[:k]\n    log_sigma = theta[k]\n    sigma = np.exp(log_sigma)\n    mu = X.dot(beta)\n    # compute probabilities\n    z_lo = (y_lo - mu) / sigma\n    # y_hi may have NaN for right-censored\n    is_right_censored = np.isnan(y_hi)\n    logpdf = np.empty(len(y_lo))\n    # For uncensored intervals\n    idx_unc = ~is_right_censored\n    if np.any(idx_unc):\n        z_hi = (y_hi[idx_unc] - mu[idx_unc]) / sigma\n        # avoid numerical issues\n        cdf_hi = stats.norm.cdf(z_hi)\n        cdf_lo = stats.norm.cdf(z_lo[idx_unc])\n        probs = cdf_hi - cdf_lo\n        probs = np.clip(probs, 1e-12, None)\n        logpdf[idx_unc] = np.log(probs)\n    # For right-censored: P(Y >= lo) = 1 - Phi(z_lo)\n    if np.any(is_right_censored):\n        cdf_lo_rc = stats.norm.cdf(z_lo[is_right_censored])\n        probs_rc = 1 - cdf_lo_rc\n        probs_rc = np.clip(probs_rc, 1e-12, None)\n        logpdf[is_right_censored] = np.log(probs_rc)\n    nll = -np.sum(logpdf)\n    return nll\n\n\ndef fit_interval_regression(X, y_lo, y_hi):\n    k = X.shape[1]\n    init_beta = np.zeros(k)\n    init_log_sigma = np.log(np.std(np.nan_to_num(y_lo - X.dot(init_beta))) + 1e-2)\n    init = np.concatenate([init_beta, [init_log_sigma]])\n    res = optimize.minimize(neg_loglik, init, args=(X, y_lo, y_hi), method='BFGS')\n    if not res.success:\n        print('Optimization warning:', res.message)\n    theta_hat = res.x\n    beta_hat = theta_hat[:k]\n    sigma_hat = np.exp(theta_hat[k])\n    # Approximate Hessian-based covariance\n    try:\n        hess_inv = res.hess_inv\n        if hasattr(hess_inv, 'todense'):\n            cov = np.array(hess_inv.todense())\n        else:\n            cov = np.array(hess_inv)\n    except Exception:\n        cov = None\n    return beta_hat, sigma_hat, cov, res\n\n\ndef cluster_bootstrap(X_df, y_lo, y_hi, ids, formula_idx, B=200, seed=0):\n    rng = np.random.RandomState(seed)\n    unique_ids = np.unique(ids)\n    n_ids = len(unique_ids)\n    boot_betas = []\n    failed = 0\n    for b in range(B):\n        sampled_ids = rng.choice(unique_ids, size=n_ids, replace=True)\n        mask = np.isin(ids, sampled_ids)\n        X_b = X_df[mask]\n        y_lo_b = y_lo[mask]\n        y_hi_b = y_hi[mask]\n        try:\n            beta_b, _, _, _ = fit_interval_regression(X_b, y_lo_b, y_hi_b)\n            boot_betas.append(beta_b)\n        except Exception as e:\n            failed += 1\n            print(f\"Bootstrap sample {b} failed: {e}\")\n    boot_betas = np.array(boot_betas)\n    if boot_betas.size == 0:\n        raise RuntimeError('All bootstrap samples failed')\n    se = np.std(boot_betas[:, formula_idx], ddof=1)\n    return se, boot_betas, failed\n\n\ndef main():\n    print('Loading data from', DATA_PATH)\n    df = load_data(DATA_PATH)\n    print('Data loaded. Rows:', len(df))\n    df_sub, X, y_lo, y_hi, ids = prepare_data(df)\n    print('After subsetting to Asian==1 and dropping missings, rows:', X.shape[0])\n    if X.shape[0] == 0:\n        print('No data to analyze. Exiting.')\n        sys.exit(1)\n    # Fit on full sample\n    beta_hat, sigma_hat, cov, res = fit_interval_regression(X, y_lo, y_hi)\n    col_names = ['intercept', 'givenprimingquestionnaire', 'largestakes', 'longterm', 'largelong']\n    results = {}\n    results['n_obs'] = int(X.shape[0])\n    results['n_clusters'] = int(len(np.unique(ids)))\n    results['params'] = {col: float(val) for col, val in zip(col_names, beta_hat)}\n    results['sigma'] = float(sigma_hat)\n    # Bootstrap cluster-robust SE for givenprimingquestionnaire (index 1)\n    idx_treat = 1\n    print('Starting cluster bootstrap with B=', B_BOOT)\n    se_boot, boot_betas, n_failed = cluster_bootstrap(X, y_lo, y_hi, ids, idx_treat, B=B_BOOT, seed=RANDOM_SEED)\n    est = float(beta_hat[idx_treat])\n    se = float(se_boot)\n    t_stat = est / se if se > 0 else None\n    # two-sided p-value using normal approx\n    p_value = 2 * (1 - stats.norm.cdf(abs(t_stat))) if t_stat is not None else None\n    ci_lower = est - 1.96 * se if se is not None else None\n    ci_upper = est + 1.96 * se if se is not None else None\n    results['focal'] = {\n        'outcome': 'lndiscrate (latent log reservation interest rate, interval-censored)',\n        'treatment': 'givenprimingquestionnaire',\n        'estimate': est,\n        'se_bootstrap': se,\n        't_stat': t_stat,\n        'p_value': p_value,\n        'ci_95': [ci_lower, ci_upper],\n        'bootstrap_failed_samples': int(n_failed),\n        'bootstrap_samples_used': int(boot_betas.shape[0])\n    }\n    # Save results\n    with open(OUTPUT_PATH, 'w') as f:\n        json.dump(results, f, indent=2)\n    print('Results written to', OUTPUT_PATH)\n    print(json.dumps(results, indent=2))\n\nif __name__ == '__main__':\n    main()\n"
})

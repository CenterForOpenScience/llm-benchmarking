Action: functions.write_file({"file_path":"data/original/31/input/replication_data/replicate_experiment1__py.py","file_content":"import json\nimport numpy as np\nimport pandas as pd\nfrom scipy import optimize, stats\n\nDATA_PATH = '/app/data/original/31/input/replication_data/REPExperiment1Data.dta'\nOUT_PATH = '/app/data/replication_results_experiment1.json'\n\ndef load_data():\n    df = pd.read_stata(DATA_PATH)\n    # Focus on Asian subjects and observations with interval bounds\n    df = df[df['asian'] == 1].copy()\n    # Use lndiscratelo and lndiscratehi as interval bounds\n    df = df[~df['lndiscratelo'].isnull()]\n    # Keep rows even if hi is NaN (right-censored)\n    return df.reset_index(drop=True)\n\ndef design_matrix(df):\n    # regressors: intercept, givenprimingquestionnaire, largestakes, longterm, largelong\n    X = np.column_stack([\n        np.ones(len(df)),\n        df['givenprimingquestionnaire'].astype(float).values,\n        df['largestakes'].astype(float).values,\n        df['longterm'].astype(float).values,\n        df['largelong'].astype(float).values\n    ])\n    return X\n\ndef neg_log_likelihood(params, X, lo, hi):\n    k = X.shape[1]\n    beta = params[:k]\n    sigma = np.exp(params[k])\n    mu = X.dot(beta)\n    z_lo = (lo - mu) / sigma\n    # hi may be NaN indicating right-censoring\n    z_hi = (hi - mu) / sigma\n    # compute probabilities\n    cdf_hi = stats.norm.cdf(z_hi, loc=0, scale=1)\n    cdf_lo = stats.norm.cdf(z_lo, loc=0, scale=1)\n    # if hi is nan, use 1 - cdf_lo\n    probs = np.where(np.isnan(z_hi), 1.0 - cdf_lo, cdf_hi - cdf_lo)\n    # to avoid log(0)\n    probs = np.clip(probs, 1e-12, None)\n    return -np.sum(np.log(probs))\n\ndef fit_interval_regression(df, maxiter=1000):\n    X = design_matrix(df)\n    lo = df['lndiscratelo'].values\n    hi = df['lndiscratehi'].values\n    k = X.shape[1]\n    # initial params: OLS on midpoints where possible\n    mid = np.where(np.isnan(hi), lo + 0.5, (lo + hi) / 2.0)\n    try:\n        ols_coef = np.linalg.lstsq(X[~np.isnan(mid)], mid[~np.isnan(mid)], rcond=None)[0]\n        init_beta = ols_coef\n    except Exception:\n        init_beta = np.zeros(k)\n    init_log_sigma = np.log(np.std(mid[~np.isnan(mid)] - X.dot(init_beta)) + 1e-4)\n    init_params = np.concatenate([init_beta, np.array([init_log_sigma])])\n    res = optimize.minimize(neg_log_likelihood, init_params, args=(X, lo, hi), method='L-BFGS-B', options={'maxiter':maxiter})\n    if not res.success:\n        print('Optimization warning:', res.message)\n    params = res.x\n    k = X.shape[1]\n    beta = params[:k]\n    sigma = np.exp(params[k])\n    return beta, sigma, res\n\ndef cluster_bootstrap_se(df, n_boot=200, random_state=12345):\n    rng = np.random.default_rng(random_state)\n    clusters = df['id'].unique()\n    coefs = []\n    for i in range(n_boot):\n        sampled_clusters = rng.choice(clusters, size=len(clusters), replace=True)\n        df_bs = pd.concat([df[df['id'] == cid] for cid in sampled_clusters], ignore_index=True)\n        try:\n            beta, sigma, res = fit_interval_regression(df_bs, maxiter=500)\n            coefs.append(beta)\n        except Exception as e:\n            # skip failed fits\n            continue\n    coefs = np.array(coefs)\n    se = np.std(coefs, axis=0, ddof=1)\n    return se, coefs\n\ndef main():\n    df = load_data()\n    if df.empty:\n        raise ValueError('No data for Asian subjects found in dataset')\n    beta, sigma, res = fit_interval_regression(df)\n    se_cluster, coefs = cluster_bootstrap_se(df, n_boot=300)\n    varnames = ['intercept', 'givenprimingquestionnaire', 'largestakes', 'longterm', 'largelong']\n    results = {'coefficients': {vn: float(b) for vn, b in zip(varnames, beta)},\n               'sigma': float(sigma),\n               'cluster_bootstrap_se': {vn: float(s) for vn, s in zip(varnames, se_cluster)},\n               'n_obs': int(len(df)),\n               'n_clusters': int(df['id'].nunique())}\n    with open(OUT_PATH, 'w') as f:\n        json.dump(results, f, indent=2)\n    print('Saved results to', OUT_PATH)\n\nif __name__ == '__main__':\n    main()\n"}) 

Action: functions.write_file({"file_path":"data/original/20/input/replication_data/analysis__py.py","file_content":"import pandas as pd\nimport statsmodels.api as sm\nimport json\n\n# Paths\nINPATH = '/app/data/original/20/input/replication_data/Kachanoff_Survey_deidentify.csv'\nOUTPATH_SUM = '/app/data/original/20/replication_negative_regression_results.json'\n\n# Read data\nDF = pd.read_csv(INPATH)\n\n# Scoring adjustments per original R script\nbai_cols = [c for c in DF.columns if c.startswith('bai') or c == 'attention_check1']\nDF.loc[:, bai_cols] = DF.loc[:, bai_cols] - 1\n\n# Intrusion/Avoidance adjust (note: original had a typo 'instrusion')\nintr_avoid_cols = [c for c in DF.columns if 'intrusion' in c or c.startswith('avoid')]\nDF.loc[:, intr_avoid_cols] = DF.loc[:, intr_avoid_cols] - 1\n\n# SDS reverse 1 and 2\nif 'sds1' in DF.columns and 'sds2' in DF.columns:\n    DF['sds1'] = 8 - DF['sds1']\n    DF['sds2'] = 8 - DF['sds2']\n\n# Composite scores\ncovid_real_cols = [c for c in DF.columns if c.startswith('covid_real')]\ncovid_symbolic_cols = [c for c in DF.columns if c.startswith('covid_symbolic')]\nnegative_cols = [c for c in DF.columns if c.startswith('negative')]\n\nDF['Realistic'] = DF[covid_real_cols].mean(axis=1)\nDF['Symbolic'] = DF[covid_symbolic_cols].mean(axis=1)\nDF['Negative'] = DF[negative_cols].sum(axis=1)\n\n# Create PROLIFIC_PID from participant_id if necessary\nif 'PROLIFIC_PID' not in DF.columns:\n    if 'participant_id' in DF.columns:\n        DF['PROLIFIC_PID'] = DF['participant_id']\n    else:\n        DF['PROLIFIC_PID'] = DF['session']\n\n# Ensure 'created' is datetime\nif 'created' in DF.columns:\n    try:\n        DF['created'] = pd.to_datetime(DF['created'])\n    except Exception:\n        pass\n\n# Order by created\nif 'created' in DF.columns:\n    DF = DF.sort_values(by='created')\n\n# Reduced variables similar to R script\nvariables = ['PROLIFIC_PID', 'created', 'BAI_total' if 'BAI_total' in DF.columns else None,\n             'Realistic', 'Symbolic', 'Intrusion' if 'Intrusion' in DF.columns else None,\n             'Avoidance' if 'Avoidance' in DF.columns else None, 'SWLS' if 'SWLS' in DF.columns else None,\n             'Positive' if 'Positive' in DF.columns else None, 'Negative', 'Social' if 'Social' in DF.columns else None,\n             'SDS' if 'SDS' in DF.columns else None, 'Norms' if 'Norms' in DF.columns else None,\n             'American' if 'American' in DF.columns else None, 'handwashing' if 'handwashing' in DF.columns else None]\n# Filter out Nones\nvariables = [v for v in variables if v is not None]\nDFreduced = DF[variables].copy()\n\n# Create time2 indicator: duplicated PROLIFIC_PID marks second occurrence\nDFreduced['time2'] = DFreduced['PROLIFIC_PID'].duplicated(keep=False) & DFreduced['PROLIFIC_PID'].duplicated(keep='first')\n# The above may mark both; instead mark second occurrence only\nDFreduced = DFreduced.reset_index(drop=True)\nDFreduced['time2'] = DFreduced.duplicated(subset=['PROLIFIC_PID'])\n\nDFtime1 = DFreduced[DFreduced['time2'] == False].copy()\nDFtime2 = DFreduced[DFreduced['time2'] == True].copy()\n\n# To mirror R merge behavior, merge DFtime1 (x) and DFtime2 (y) by PROLIFIC_PID\nDFwide = pd.merge(DFtime1, DFtime2, on='PROLIFIC_PID', suffixes=('.x', '.y'))\n\n# Check sample size\nn_pairs = DFwide.shape[0]\n\n# Regression: Negative.y ~ Realistic.x + Symbolic.x\nif {'Negative.y', 'Realistic.x', 'Symbolic.x'}.issubset(DFwide.columns):\n    y = DFwide['Negative.y']\n    X = DFwide[['Realistic.x', 'Symbolic.x']]\n    X = sm.add_constant(X)\n    model = sm.OLS(y, X, missing='drop').fit()\n    coef_table = model.params.to_dict()\n    pvalues = model.pvalues.to_dict()\n    summary = model.summary().as_text()\nelse:\n    # If column names differ (e.g., Negative, Realistic), try alternate\n    if {'Negative', 'Realistic', 'Symbolic'}.issubset(DFwide.columns):\n        y = DFwide['Negative']\n        X = DFwide[['Realistic', 'Symbolic']]\n        X = sm.add_constant(X)\n        model = sm.OLS(y, X, missing='drop').fit()\n        coef_table = model.params.to_dict()\n        pvalues = model.pvalues.to_dict()\n        summary = model.summary().as_text()\n    else:\n        coef_table = {}\n        pvalues = {}\n        summary = 'Required columns not found in DFwide.'\n\nresults = {\n    'n_pairs': int(n_pairs),\n    'coefficients': coef_table,\n    'pvalues': pvalues,\n    'summary': summary\n}\n\n# Save results\nwith open(OUTPATH_SUM, 'w') as f:\n    json.dump(results, f, indent=2)\n\nprint('Done. Results saved to', OUTPATH_SUM)\n"} )

Action: functions.write_file({"file_path":"data/original/22/input/replication_data/replicate_analysis__py.py","file_content":"import os\nimport json\nimport numpy as np\nimport pandas as pd\nimport statsmodels.api as sm\n\n\ndef compute_k10_category(total):\n    # K10 categories: 10-19 none, 20-24 mild, 25-29 moderate, 30-50 severe\n    if pd.isna(total):\n        return np.nan\n    if total <= 19:\n        return 'none'\n    elif total <= 24:\n        return 'mild'\n    elif total <= 29:\n        return 'moderate'\n    else:\n        return 'severe'\n\n\ndef main():\n    # Primary data path expected in container\n    primary_path = '/app/data/AlTammemi_Survey_deidentify.csv'\n    fallback_path = 'data/original/22/input/replication_data/AlTammemi_Survey_deidentify.csv'\n    if os.path.exists(primary_path):\n        data_path = primary_path\n    elif os.path.exists(fallback_path):\n        data_path = fallback_path\n    else:\n        raise FileNotFoundError('Survey CSV not found in expected locations.')\n\n    df = pd.read_csv(data_path)\n\n    # Ensure Kessler items exist\n    k_items = [f'Kessler_{i}' for i in range(1, 11)]\n    for k in k_items:\n        if k not in df.columns:\n            raise ValueError(f'Missing expected column: {k}')\n\n    # Compute K10 total; drop rows with missing K items\n    df['k10_total'] = df[k_items].sum(axis=1, min_count=10)\n\n    # Categorize\n    df['k10_category'] = df['k10_total'].apply(compute_k10_category)\n    df['severe'] = (df['k10_category'] == 'severe').astype(float)\n\n    # Motivation variable: online_learning_1 (1-4). Following original paper, treat 1 as 'no motivation'\n    if 'online_learning_1' not in df.columns:\n        raise ValueError('Missing expected column: online_learning_1')\n    df['no_motivation'] = (df['online_learning_1'] == 1).astype(float)\n\n    # Age: derive from demographic_1 if it appears to be birthyear\n    if 'demographic_1' in df.columns:\n        # if values look like years (>=1900), convert to age using 2020 as survey year\n        birth = df['demographic_1']\n        df['age'] = np.where((birth >= 1900) & (birth <= 2025), 2020 - birth, np.nan)\n    else:\n        df['age'] = np.nan\n\n    # Include basic covariates if present\n    covariates = ['age']\n    # demographic_2: likely gender (1/2)\n    if 'demographic_2' in df.columns:\n        df['demographic_2'] = df['demographic_2'].astype('category')\n        # create dummy, drop first\n        d2 = pd.get_dummies(df['demographic_2'], prefix='demographic_2', drop_first=True)\n        df = pd.concat([df, d2], axis=1)\n        covariates += list(d2.columns)\n\n    # demographic_3 and demographic_4 may capture academic level / enrollment; include if present\n    for col in ['demographic_3', 'demographic_4']:\n        if col in df.columns:\n            df[col] = df[col].astype('category')\n            dummies = pd.get_dummies(df[col], prefix=col, drop_first=True)\n            df = pd.concat([df, dummies], axis=1)\n            covariates += list(dummies.columns)\n\n    # Prepare model data: drop rows with missing outcome or primary predictor\n    model_df = df.dropna(subset=['severe', 'no_motivation'])\n\n    # Additionally drop rows with missing K10 total (outcome missing)\n    model_df = model_df[~model_df['k10_total'].isna()].copy()\n\n    # Design matrix\n    X = model_df[['no_motivation'] + [c for c in covariates if c in model_df.columns]]\n    X = sm.add_constant(X, has_constant='add')\n    y = model_df['severe']\n\n    # Fit logistic regression\n    try:\n        logit_model = sm.Logit(y, X.astype(float))\n        result = logit_model.fit(disp=False)\n    except Exception as e:\n        # fallback to GLM if perfect separation or other issues\n        glm_model = sm.GLM(y, X.astype(float), family=sm.families.Binomial())\n        result = glm_model.fit()\n\n    coef = result.params.get('no_motivation', np.nan)\n    se = result.bse.get('no_motivation', np.nan)\n    pval = result.pvalues.get('no_motivation', np.nan)\n\n    # Odds ratio and 95% CI\n    or_val = np.exp(coef) if not pd.isna(coef) else np.nan\n    ci = result.conf_int().loc['no_motivation'].values if 'no_motivation' in result.params.index else [np.nan, np.nan]\n    ci_or = [float(np.exp(ci[0])), float(np.exp(ci[1]))] if not any(pd.isna(ci)) else [np.nan, np.nan]\n\n    output = {\n        'n_total_records': int(df.shape[0]),\n        'n_model_records': int(model_df.shape[0]),\n        'k10_mean': float(df['k10_total'].mean(skipna=True)) if 'k10_total' in df.columns else None,\n        'severe_prevalence_pct': float(100 * df['severe'].mean()) if 'severe' in df.columns else None,\n        'model': {\n            'coef_no_motivation': None if pd.isna(coef) else float(coef),\n            'or_no_motivation': None if pd.isna(or_val) else float(or_val),\n            'or_ci_lower': ci_or[0],\n            'or_ci_upper': ci_or[1],\n            'p_value_no_motivation': None if pd.isna(pval) else float(pval),\n            'model_summary': result.summary().as_text()\n        }\n    }\n\n    # Save results to /app/data\n    out_path = '/app/data/replication_results_AlTammemi.json'\n    try:\n        with open(out_path, 'w') as f:\n            json.dump(output, f, indent=2)\n    except Exception:\n        # fallback to local path\n        out_path_local = 'data/original/22/input/replication_data/replication_results_AlTammemi.json'\n        with open(out_path_local, 'w') as f:\n            json.dump(output, f, indent=2)\n\n    print('Analysis complete. Results written to', out_path)\n\n\nif __name__ == '__main__':\n    main()\n","overwrite":false})

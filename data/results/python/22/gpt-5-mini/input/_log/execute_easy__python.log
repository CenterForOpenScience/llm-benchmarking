    for p in CANDIDATE_PATHS:
        if os.path.exists(p):
            return p
    raise FileNotFoundError('Could not find AlTammemi_Survey_deidentify.csv in expected paths.')


def safe_float(x):
    try:
        return float(x)
    except:
        return np.nan


def main():
    csv_path = find_csv()
    print('Using dataset:', csv_path)

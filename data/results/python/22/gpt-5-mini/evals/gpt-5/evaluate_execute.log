            return 'none'
        elif 20 <= score <= 24:
            return 'mild'
        elif 25 <= score <= 29:
            return 'moderate'
        else:
            return 'severe'
    df['K10_category'] = df['K10_total'].apply(k10_category)
    df['severe'] = df['K10_total'] >= 30
    # Predictor: online_learning_1
    if 'online_learning_1' not in df.columns:

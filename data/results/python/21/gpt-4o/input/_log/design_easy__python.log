  "file_content": "import pandas as pd\nimport statsmodels.formula.api as smf\n\n# Load the data\nDF1 = pd.read_csv('/app/data/Bischetti_Survey_Part1_deidentify.csv')\nDF2 = pd.read_csv('/app/data/Bischetti_Survey_Part2_deidentify.csv')\n\n# Merge the datasets\nDF = pd.merge(DF1, DF2, on='participant_id', how='outer')\n\n# Restructure the data\nDF_long = DF.melt(id_vars=['participant_id', 'state', 'age'], \n                  value_vars=[col for col in DF.columns if 'disturbing' in col],\n                  var_name='name', value_name='Aversiveness')\n\n# Clean the 'name' column\nDF_long['name'] = DF_long['name'].str.replace('disturbing', 'anote')\n\n# Load metadata\nmeta_data1 = pd.read_excel('/app/data/Bischetti_Survey_Part1.xlsx')\nmeta_data2 = pd.read_excel('/app/data/Bischetti_Survey_Part2.xlsx')\nmeta_data = pd.concat([meta_data1, meta_data2])\n\n# Merge metadata with the main dataset\nDF_long = DF_long.merge(meta_data[['name', 'label']], on='name', how='left')\n\n# Clean the 'label' column\nDF_long['label'] = DF_long['label'].str.replace('<img src =\\'http://formr.thedoomlab.com/img/', '')\nDF_long['label'] = DF_long['label'].str.replace('-[0-9]*.jpg\\'>', '')\n\n# Fit the multilevel model\nmodel = smf.mixedlm('Aversiveness ~ label', DF_long, \n                    groups=DF_long['participant_id'], \n                    re_formula='~label')\nresult = model.fit()\n\nprint(result.summary())",

META_CANDIDATES  = [
    os.path.join(DATA_DIR, 'stimulus_metadata.csv'),
    os.path.join(DATA_DIR, 'replication_data', 'stimulus_metadata.csv')
]

def first_existing(candidates):
    for p in candidates:
        if os.path.exists(p):

DATA_DIR = Path(__file__).resolve().parent
CSV_PATH = DATA_DIR / "gelfand_replication_data.csv"

# Countries flagged for exclusion by the original authors
EXCLUDE_COUNTRIES = [
    "Belgium",
    "France",
    "New Zealand",
    "Norway",
    "Pakistan",
    "Venezuela",
]


def load_and_preprocess():
    df = pd.read_csv(CSV_PATH)


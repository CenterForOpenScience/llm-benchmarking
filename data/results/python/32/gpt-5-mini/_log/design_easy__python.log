Action: functions.write_file({"file_path":"data/original/32/input/replication_data/Script__py.py","file_content":"import pandas as pd\nimport numpy as np\nfrom scipy import stats\n\n# Read data from expected mounted path\nfn = '/app/data/Data_Cleaned_22102020.csv'\n# Try reading with utf-8 and handle weird separators\ndf = pd.read_csv(fn, dtype=str)\n\n# Clean column names (strip BOM and whitespace)\ndf.columns = [c.strip().replace('\\ufeff','') for c in df.columns]\n\n# Keep a copy\ndata = df.copy()\n\n# Convert relevant columns to numeric where possible\nfor col in ['Lot_check','Gift_check','Lot_WTPc','Gift_WTPc']:\n    if col in data.columns:\n        # Remove dollar signs, commas and whitespace\n        data[col] = data[col].astype(str).str.replace('\\\\$', '', regex=True).str.replace(',', '', regex=True).str.strip()\n        data[col] = pd.to_numeric(data[col].replace({'':np.nan,'NA':np.nan,'NaN':np.nan}), errors='coerce')\n    else:\n        data[col] = np.nan\n\n# Create Cond variable following the R script logic\n# Initialize as NaN\ndata['Cond'] = np.nan\n# If Lot_check > 0 => lottery (0)\ndata.loc[data['Lot_check']>0, 'Cond'] = 'lottery'\n# If Gift_check > 0 => gift (1) (this can override lottery if both present, matching R order)\ndata.loc[data['Gift_check']>0, 'Cond'] = 'gift'\n\n# Create WTP per condition\n# If lottery use Lot_WTPc, if gift use Gift_WTPc\ndata['WTP'] = np.where(data['Cond']=='lottery', data['Lot_WTPc'], np.where(data['Cond']=='gift', data['Gift_WTPc'], np.nan))\n\n# Drop rows with missing WTP (as in R: data <- data[!is.na(data$WTP),])\ndata = data[~data['WTP'].isna()].copy()\n\n# Create check variable depending on condition\ndata['check'] = np.where(data['Cond']=='lottery', data['Lot_check'], np.where(data['Cond']=='gift', data['Gift_check'], np.nan))\n\n# Critical test: select those who answered correctly (check == 3)\ndataS = data[data['check']==3].copy()\n# Save selected data\ntry:\n    dataS.to_csv('/app/data/dataS.csv', index=False)\nexcept Exception as e:\n    pass\n\n# Helper to compute descriptive stats\ndef describe_by(series):\n    series = series.dropna()\n    return {'N': int(series.count()), 'mean': float(series.mean()), 'std': float(series.std(ddof=1))}\n\n# Prepare results string\nout_lines = []\nout_lines.append('Replication analysis results:\\n')\n\n# Grouped descriptives\nif 'Cond' in dataS.columns:\n    groups = dataS.groupby('Cond')['WTP']\n    for name, grp in groups:\n        desc = describe_by(grp.astype(float))\n        out_lines.append(f\"Group={name}: N={desc['N']}, mean={desc['mean']:.4f}, sd={desc['std']:.4f}\\n\")\n\n# T-test (Welch) between conditions for dataS\ntry:\n    wtp_lot = dataS[dataS['Cond']=='lottery']['WTP'].dropna().astype(float)\n    wtp_gift = dataS[dataS['Cond']=='gift']['WTP'].dropna().astype(float)\n    tstat, pval = stats.ttest_ind(wtp_lot, wtp_gift, equal_var=False, nan_policy='omit')\n    out_lines.append(f\"T-test (Welch) dataS: t={tstat:.4f}, p={pval:.4g}, n_lottery={len(wtp_lot)}, n_gift={len(wtp_gift)}\\n\")\n    # Cohen's d (pooled sd)\n    n1, n2 = len(wtp_lot), len(wtp_gift)\n    s1, s2 = wtp_lot.std(ddof=1), wtp_gift.std(ddof=1)\n    pooled_sd = np.sqrt(((n1-1)*s1**2 + (n2-1)*s2**2) / (n1 + n2 - 2)) if (n1 + n2 - 2) > 0 else np.nan\n    d = (wtp_lot.mean() - wtp_gift.mean()) / pooled_sd if pooled_sd>0 else np.nan\n    out_lines.append(f\"Cohen_d dataS (pooled SD): d={d:.4f}\\n\")\nexcept Exception as e:\n    out_lines.append('T-test or Cohen d failed for dataS: ' + str(e) + '\\n')\n\n# Select those who answered 20 or less\ndataSC = dataS[dataS['WTP']<=20].copy()\ntry:\n    dataSC.to_csv('/app/data/dataSC.csv', index=False)\nexcept Exception:\n    pass\n\n# Descriptives and tests for dataSC\nif not dataSC.empty:\n    groups_sc = dataSC.groupby('Cond')['WTP']\n    for name, grp in groups_sc:\n        desc = describe_by(grp.astype(float))\n        out_lines.append(f\"(<=20) Group={name}: N={desc['N']}, mean={desc['mean']:.4f}, sd={desc['std']:.4f}\\n\")\n    try:\n        wtp_lot_sc = dataSC[dataSC['Cond']=='lottery']['WTP'].dropna().astype(float)\n        wtp_gift_sc = dataSC[dataSC['Cond']=='gift']['WTP'].dropna().astype(float)\n        tstat_sc, pval_sc = stats.ttest_ind(wtp_lot_sc, wtp_gift_sc, equal_var=False, nan_policy='omit')\n        out_lines.append(f\"T-test (Welch) dataSC: t={tstat_sc:.4f}, p={pval_sc:.4g}, n_lottery={len(wtp_lot_sc)}, n_gift={len(wtp_gift_sc)}\\n\")\n        # Cohen's d\n        n1_sc, n2_sc = len(wtp_lot_sc), len(wtp_gift_sc)\n        s1_sc, s2_sc = wtp_lot_sc.std(ddof=1), wtp_gift_sc.std(ddof=1)\n        pooled_sd_sc = np.sqrt(((n1_sc-1)*s1_sc**2 + (n2_sc-1)*s2_sc**2) / (n1_sc + n2_sc - 2)) if (n1_sc + n2_sc - 2) > 0 else np.nan\n        d_sc = (wtp_lot_sc.mean() - wtp_gift_sc.mean()) / pooled_sd_sc if pooled_sd_sc>0 else np.nan\n        out_lines.append(f\"Cohen_d dataSC (pooled SD): d={d_sc:.4f}\\n\")\n    except Exception as e:\n        out_lines.append('T-test or Cohen d failed for dataSC: ' + str(e) + '\\n')\nelse:\n    out_lines.append('No observations with WTP <= 20 after filtering.\\n')\n\n# Write results to file\ntry:\n    with open('/app/data/replication_results.txt', 'w') as f:\n        f.writelines('\\n'.join(out_lines))\nexcept Exception as e:\n    print('Failed to write results file:', e)\n\n# Also print to stdout\nprint('\\n'.join(out_lines))\n"} )

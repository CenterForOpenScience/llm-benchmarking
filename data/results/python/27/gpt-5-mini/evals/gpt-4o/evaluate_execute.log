{"file_path":"data/original/27/input/replication_data/replication_analysis__py.py","file_content":"import pandas as pd\nimport numpy as np\nfrom scipy.stats import wilcoxon\n\n# Paths (assume /app/data is mounted to working directory)\nround1_path = '/app/data/data/original/27/input/replication_data/round1_raw.csv'\nround2_path = '/app/data/data/original/27/input/replication_data/round2_raw.csv'\nout_round1 = '/app/data/data/original/27/input/replication_data/round1_analysis.csv'\nout_full = '/app/data/data/original/27/input/replication_data/fullsample_analysis.csv'\n\n# helper to process a raw dataframe similar to the Stata .do\ndef process_raw(df):\n    # Keep groups where ipo_task.1.group.id_in_subsession > 1\n    grpcol = 'ipo_task.1.group.id_in_subsession'\n    df = df[df[grpcol] > 1].copy()\n\n    # rename market price columns for rounds 1..20\n    for r in range(1,21):\n        old = f'ipo_task.{r}.group.market_price'\n        new = f'price{r}'\n        if old in df.columns:\n            df.rename(columns={old: new}, inplace=True)\n\n    # rounds_missed col\n    if 'ipo_task.20.playertotal_missing_re' in df.columns:\n        df = df.rename(columns={'ipo_task.20.playertotal_missing_re':'rounds_missed'})\n    elif 'ipo_task.20playertotal_missing_re' in df.columns:\n        df = df.rename(columns={'ipo_task.20playertotal_missing_re':'rounds_missed'})\n\n    # select id vars for reshape\n    id_vars = ['ipo_task.1.group.id_in_subsession','ipo_task.1.player.id_in_group','session.code','rounds_missed']\n    # ensure columns exist\n    id_vars = [c for c in id_vars if c in df.columns]\n\n    # gather price columns\n    price_cols = [f'price{r}' for r in range(1,21) if f'price{r}' in df.columns]\n\n    # reshape wide to long\n    long = df[id_vars + price_cols].melt(id_vars=id_vars, value_vars=price_cols, var_name='round', value_name='price')\n    # extract round number\n    long['round'] = long['round'].str.replace('price','').astype(int)\n\n    # create group id similar to Stata egen group(ipo_task1groupid_in_subsession sessioncode)\n    if 'ipo_task.1.group.id_in_subsession' in long.columns and 'session.code' in long.columns:\n        long['group'] = long.groupby(['ipo_task.1.group.id_in_subsession','session.code']).ngroup()+1\n    else:\n        long['group'] = long['ipo_task.1.group.id_in_subsession'] if 'ipo_task.1.group.id_in_subsession' in long.columns else 1\n\n    # collapse by group and round: mean price, max rounds_missed, min rounds_missed\n    agg = long.groupby(['group','round']).agg(\n        price=('price','mean'),\n        rounds_missed_max=('rounds_missed','max') if 'rounds_missed' in long.columns else ('rounds_missed', lambda x: np.nan),\n        rounds_missed_min=('rounds_missed','min') if 'rounds_missed' in long.columns else ('rounds_missed', lambda x: np.nan)\n    ).reset_index()\n\n    # create dropout and bankrupt\n    agg['dropout'] = 0\n    agg.loc[agg['rounds_missed_max']>=6,'dropout'] = 1\n    agg['bankrupt'] = 0\n    agg.loc[agg['rounds_missed_min']==-99,'bankrupt'] = 1\n\n    return agg\n\n# process round1\nr1 = pd.read_csv(round1_path)\nagg1 = process_raw(r1)\n\n# perform Wilcoxon signed-rank test vs 1.94 on price for different subsets\n# note: scipy wilcoxon requires paired samples; we test price-1.94 against zero\nprice_vals = agg1['price'].dropna()\ntry:\n    stat_all = wilcoxon(price_vals - 1.94)\nexcept Exception as e:\n    stat_all = (np.nan, np.nan)\n\nprice_nodrop = agg1.loc[agg1['dropout']==0,'price'].dropna()\ntry:\n    stat_nodrop = wilcoxon(price_nodrop - 1.94)\nexcept Exception as e:\n    stat_nodrop = (np.nan, np.nan)\n\nprice_clean = agg1.loc[(agg1['dropout']==0)&(agg1['bankrupt']==0),'price'].dropna()\ntry:\n    stat_clean = wilcoxon(price_clean - 1.94)\nexcept Exception as e:\n    stat_clean = (np.nan, np.nan)\n\n# collapse mean price by group\ngroup_mean = agg1.groupby('group').agg(price=('price','mean'), dropout=('dropout','max'), bankrupt=('bankrupt','max')).reset_index()\n# save round1_analysis.csv\ngroup_mean.to_csv(out_round1,index=False)\n\n# now append round2 and repeat for full sample\nr2 = pd.read_csv(round2_path)\n# The original STATA code appends using round1raw then repeats same operations; easier is to concat raw dfs then process\ncombined = pd.concat([r1,r2],ignore_index=True)\nagg_full = process_raw(combined)\n# perform tests on full as in DO\nprice_vals_full = agg_full['price'].dropna()\ntry:\n    stat_all_full = wilcoxon(price_vals_full - 1.94)\nexcept Exception as e:\n    stat_all_full = (np.nan, np.nan)\n\nprice_nodrop_full = agg_full.loc[agg_full['dropout']==0,'price'].dropna()\ntry:\n    stat_nodrop_full = wilcoxon(price_nodrop_full - 1.94)\nexcept Exception as e:\n    stat_nodrop_full = (np.nan, np.nan)\n\nprice_clean_full = agg_full.loc[(agg_full['dropout']==0)&(agg_full['bankrupt']==0),'price'].dropna()\ntry:\n    stat_clean_full = wilcoxon(price_clean_full - 1.94)\nexcept Exception as e:\n    stat_clean_full = (np.nan, np.nan)\n\n# collapse mean price by group for full\ngroup_mean_full = agg_full.groupby('group').agg(price=('price','mean'), rounds_missed_max=('rounds_missed_max','max'), dropout=('dropout','max'), bankrupt=('bankrupt','max')).reset_index()\ngroup_mean_full.to_csv(out_full,index=False)\n\n# print test outputs to stdout for logging\nprint('round1 tests:', stat_all, stat_nodrop, stat_clean)\nprint('full tests:', stat_all_full, stat_nodrop_full, stat_clean_full)\n"} 

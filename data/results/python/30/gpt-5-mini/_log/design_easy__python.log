Action: functions.write_file({"file_path":"data/original/30/input/replication_data/Analysis__py.py","file_content":"import os\nimport pandas as pd\nimport numpy as np\nimport statsmodels.formula.api as smf\nimport statsmodels.api as sm\n\n# Paths: primary data location per run policy\nprimary_path = '/app/data/Full_long.dta'\nfallback_path = 'data/original/30/input/replication_data/Full_long.dta'\n\nif os.path.exists(primary_path):\n    data_path = primary_path\nelif os.path.exists(fallback_path):\n    data_path = fallback_path\nelse:\n    raise FileNotFoundError(f\"Could not find Full_long.dta in /app/data or fallback path\")\n\n# Read data\nprint('Loading', data_path)\ndf = pd.read_stata(data_path)\n\n# Create variables following the Analysis.do logic\ndf['nvst'] = np.where(df['round'] > 2, df['playerinvestment'], np.nan)\n# pstn mapping A-E to 1-5\nrole_map = {'A':1, 'B':2, 'C':3, 'D':4, 'E':5}\ndf['pstn'] = df['playerrole'].map(role_map)\n\n# rnd = round - 2 when round > 2\ndf['rnd'] = np.where(df['round'] > 2, df['round'] - 2, np.nan)\n\n# dwnld is playerdownloaded_files if round >2\nif 'playerdownloaded_files' in df.columns:\n    df['dwnld'] = np.where(df['round'] > 2, df['playerdownloaded_files'], np.nan)\nelse:\n    df['dwnld'] = np.nan\n\n# pyff = playercollected_tokens + (10 - playerinvestment) if round > 2\nif 'playercollected_tokens' in df.columns and 'playerinvestment' in df.columns:\n    df['pyff'] = np.where(df['round'] > 2, df['playercollected_tokens'] + (10 - df['playerinvestment']), np.nan)\nelse:\n    df['pyff'] = np.nan\n\n# grp and identifiers\nif 'Session' in df.columns and 'groupid_in_subsession' in df.columns:\n    df['grp'] = df['Session']*100 + df['groupid_in_subsession']\nelse:\n    # fallback: use sessioncode and groupid if present\n    if 'sessioncode' in df.columns and 'groupid_in_subsession' in df.columns:\n        df['grp'] = df['sessioncode']*100 + df['groupid_in_subsession']\n    else:\n        # create a group id from existing columns\n        df['grp'] = df['groupid_in_subsession'].fillna(0)\n\n# idrnd and grprnd\ndf['idrnd'] = df['id']*100 + df['rnd']\ndf['grprnd'] = df['grp']*100 + df['rnd']\n\n# dwnldpyff\ndf['dwnldpyff'] = np.where(df['round'] > 2, df['playercollected_tokens'], np.nan)\n# bndwdth\ndf['bndwdth'] = np.where(df['round'] > 2, df.get('groupbandwidth', np.nan), np.nan)\n\n# Work on rounds >2 subset per do file\ndf_v1 = df[df['round'] > 2].copy()\n\n# Aggregate group sums by grprnd\ngrp_sums = df_v1.groupby('grprnd').agg(grpnvst=('nvst', 'sum'), grpdwnldpyff=('dwnldpyff', 'sum')).reset_index()\n\n# Merge back\ndf_v1 = df_v1.merge(grp_sums, on='grprnd', how='left')\n\n# Compute shares (with defaults per do file)\n# shrnvst = nvst / grpnvst if grpnvst > 0 else 0.2\ndf_v1['shrnvst'] = np.where(df_v1['grpnvst'] > 0, df_v1['nvst'] / df_v1['grpnvst'], 0.2)\n# shrdwnld = dwnldpyff / grpdwnldpyff if grpdwnldpyff > 0 else 0.2\ndf_v1['shrdwnld'] = np.where(df_v1['grpdwnldpyff'] > 0, df_v1['dwnldpyff'] / df_v1['grpdwnldpyff'], 0.2)\n\n# Create lag of shrdwnld by individual id ordered by rnd (analogous to xtset id rnd and L1.)\n# Ensure rnd is numeric and sort\ndf_v1 = df_v1.sort_values(['id', 'rnd'])\n# groupby id and shift\ndf_v1['shr'] = df_v1.groupby('id')['shrdwnld'].shift(1)\n\n# Interaction terms\ndf_v1['pstnshr'] = df_v1['pstn'] * df_v1['shr']\ndf_v1['pstnshrnvst'] = df_v1['pstn'] * df_v1['shrnvst']\n\n# Save processed dataset for inspection\nout_proc_path = '/app/data/Full_long_v2.csv'\ntry:\n    df_v1.to_csv(out_proc_path, index=False)\n    print('Saved processed data to', out_proc_path)\nexcept Exception as e:\n    # fallback to local path\n    df_v1.to_csv('data/original/30/input/replication_data/Full_long_v2.csv', index=False)\n    print('Saved processed data to fallback path', 'data/original/30/input/replication_data/Full_long_v2.csv')\n\n# Prepare results output\nresults = []\n\n# Summaries by position\nfor p in [1,2,3,4,5]:\n    sub = df_v1[df_v1['pstn'] == p]\n    results.append(f\"Summary nvst for pstn={p}: n={len(sub)}, mean={sub['nvst'].mean():.3f}, std={sub['nvst'].std():.3f}\")\n\n# Mixed effects models\n# Model 1: mixed nvst pstn shr pstnshr rnd || grp:\ntry:\n    md1 = smf.mixedlm('nvst ~ pstn + shr + pstn:shr + rnd', df_v1, groups=df_v1['grp'])\n    mdf1 = md1.fit(reml=False)\n    results.append('\\nMixedLM nvst ~ pstn * shr + rnd (REML=False)\\n')\n    results.append(str(mdf1.summary()))\nexcept Exception as e:\n    results.append('MixedLM nvst model failed: ' + str(e))\n\n# Model 2: mixed nvst ... reml\ntry:\n    md1r = smf.mixedlm('nvst ~ pstn + shr + pstn:shr + rnd', df_v1, groups=df_v1['grp'])\n    mdf1r = md1r.fit(reml=True)\n    results.append('\\nMixedLM nvst ~ pstn * shr + rnd (REML=True)\\n')\n    results.append(str(mdf1r.summary()))\nexcept Exception as e:\n    results.append('MixedLM nvst REML model failed: ' + str(e))\n\n# Model for dwnldpyff\ntry:\n    md2 = smf.mixedlm('dwnldpyff ~ bndwdth + pstn + shrnvst + pstn:shrnvst + rnd', df_v1, groups=df_v1['grp'])\n    mdf2 = md2.fit(reml=False)\n    results.append('\\nMixedLM dwnldpyff ~ bndwdth + pstn * shrnvst + rnd (REML=False)\\n')\n    results.append(str(mdf2.summary()))\nexcept Exception as e:\n    results.append('MixedLM dwnldpyff model failed: ' + str(e))\n\n# Save results\nres_path = '/app/data/regression_results.txt'\ntry:\n    with open(res_path, 'w') as f:\n        for line in results:\n            f.write(line + '\\n\\n')\n    print('Saved regression results to', res_path)\nexcept Exception as e:\n    with open('data/original/30/input/replication_data/regression_results.txt', 'w') as f:\n        for line in results:\n            f.write(line + '\\n\\n')\n    print('Saved regression results to fallback path', 'data/original/30/input/replication_data/regression_results.txt')\n\nprint('Analysis complete.')\n"})

full_long_v1['shrdwnld'] = full_long_v1.apply(lambda row: row['dwnldpyff'] / row['grpdwnldpyff'] if row['grpdwnldpyff'] > 0 else 0.2, axis=1)

# Lagged share variable
full_long_v1['shr'] = full_long_v1['shrdwnld'].shift(1)

# Interaction terms

{
  "file_path": "data/original/30/input/replication_data/Analysis__py.py",
  "file_content": "import pandas as pd\nfrom statsmodels.regression.mixed_linear_model import MixedLM\n\n# Load the dataset\nfull_long = pd.read_stata('/app/data/Full_long.dta')\n\n# Generate new variables\nfull_long['nvst'] = full_long['playerinvestment'].where(full_long['round'] > 2, other=pd.NA)\nfull_long['pstn'] = full_long['playerrole'].map({'A': 1, 'B': 2, 'C': 3, 'D': 4, 'E': 5})\nfull_long['rnd'] = (full_long['round'] - 2).where(full_long['round'] > 2, other=pd.NA)\nfull_long['dwnld'] = full_long['playerdownloaded_files'].where(full_long['round'] > 2, other=pd.NA)\nfull_long['pyff'] = (full_long['playercollected_tokens'] + (10 - full_long['playerinvestment'])).where(full_long['round'] > 2, other=pd.NA)\nfull_long['grp'] = full_long['Session'] * 100 + full_long['groupid_in_subsession']\nfull_long['idrnd'] = full_long['id'] * 100 + full_long['rnd']\nfull_long['grprnd'] = full_long['grp'] * 100 + full_long['rnd']\nfull_long['dwnldpyff'] = full_long['playercollected_tokens'].where(full_long['round'] > 2, other=pd.NA)\nfull_long['bndwdth'] = full_long['groupbandwidth'].where(full_long['round'] > 2, other=pd.NA)\n\n# Save intermediate dataset\nfull_long.to_stata('/app/data/Full_long_v1.dta')\n\n# Collapse data\nsums = full_long[full_long['round'] >= 3].groupby('grprnd').agg({'nvst': 'sum', 'dwnldpyff': 'sum'}).rename(columns={'nvst': 'grpnvst', 'dwnldpyff': 'grpdwnldpyff'})\nsums.to_stata('/app/data/Sums.dta')\n\n# Merge datasets\nfull_long_v1 = pd.read_stata('/app/data/Full_long_v1.dta')\nfull_long_v1 = full_long_v1[full_long_v1['round'] >= 3]\nfull_long_v1 = full_long_v1.merge(sums, on='grprnd', how='left')\n\n# Generate share variables\nfull_long_v1['shrnvst'] = full_long_v1.apply(lambda row: row['nvst'] / row['grpnvst'] if row['grpnvst'] > 0 else 0.2, axis=1)\nfull_long_v1['shrdwnld'] = full_long_v1.apply(lambda row: row['dwnldpyff'] / row['grpdwnldpyff'] if row['grpdwnldpyff'] > 0 else 0.2, axis=1)\n\n# Generate lagged and interaction variables\nfull_long_v1['shr'] = full_long_v1['shrdwnld'].shift(1)\nfull_long_v1['pstnshr'] = full_long_v1['pstn'] * full_long_v1['shr']\nfull_long_v1['pstnshrnvst'] = full_long_v1['pstn'] * full_long_v1['shrnvst']\n\n# Save final dataset\nfull_long_v1.to_stata('/app/data/Full_long_v2.dta')\n\n# Load final dataset for analysis\nfull_long_v2 = pd.read_stata('/app/data/Full_long_v2.dta')\n\n# Define and fit mixed-effects models\nmodel_nvst = MixedLM.from_formula('nvst ~ pstn + shr + pstnshr + rnd', groups='grp', data=full_long_v2)\nresult_nvst = model_nvst.fit()\nprint(result_nvst.summary())\n\nmodel_dwnldpyff = MixedLM.from_formula('dwnldpyff ~ bndwdth + pstn + shrnvst + pstnshrnvst + rnd', groups='grp', data=full_long_v2)\nresult_dwnldpyff = model_dwnldpyff.fit()\nprint(result_dwnldpyff.summary())\n\n# Additional models with interaction terms\nmodel_nvst_interaction = MixedLM.from_formula('nvst ~ pstn * shr + rnd', groups='grp', data=full_long_v2)\nresult_nvst_interaction = model_nvst_interaction.fit(reml=True)\nprint(result_nvst_interaction.summary())\n\nmodel_dwnldpyff_interaction = MixedLM.from_formula('dwnldpyff ~ bndwdth + pstn * shrnvst + rnd', groups='grp', data=full_long_v2)\nresult_dwnldpyff_interaction = model_dwnldpyff_interaction.fit(reml=True)\nprint(result_dwnldpyff_interaction.summary())\n"
}

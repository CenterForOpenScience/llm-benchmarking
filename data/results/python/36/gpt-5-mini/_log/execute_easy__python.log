Cordata<-Popper.Data.for.Correlations


apa.cor.table(
  Cordata,
  filename = "PopperAmitCorr1.doc",
  table.number = 1,
  show.sig.stars = TRUE,
  landscape = TRUE
)

##Scale Reliabilities

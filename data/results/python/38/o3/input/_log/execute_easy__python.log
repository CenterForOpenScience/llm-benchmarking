"""
Replication analysis for McCarter et al. (2010) focal hypothesis.
Loads the cleaned dataset and estimates whether contributions (cont)
are lower when the bonus structure includes the possibility of losses
(losses == 1) compared to gains-only / no-variance (losses == 0).

We follow the original .do script which fitted a linear mixed model with
random intercepts for session and participant (id).  Using statsmodels we
specify the participant as the primary grouping factor and include a
variance component for session.  The main coefficient of interest is on
``losses``.  A negative and significant coefficient supports the
hypothesis.

All paths are relative to /app/data as required by the execution
environment.
"""
from pathlib import Path
import pandas as pd
import statsmodels.api as sm
from statsmodels.regression.mixed_linear_model import MixedLM

# Paths
DATA_PATH = Path("/app/data/McCarter_OrgBehavior_2010_pILK data CLEAN.csv")


def main():
    # Load data
    df = pd.read_csv(DATA_PATH)

    # Keep only necessary columns
    df_model = df[["cont", "losses", "id", "sessioncode"]].copy()

    # Drop any rows with missing outcome or key predictors
    df_model = df_model.dropna(subset=["cont", "losses", "id", "sessioncode"])

    # Add intercept
    df_model["intercept"] = 1.0

    # Define model: cont ~ losses, random intercept for participants (id)
    # and session as a variance component.
    vc = {"session": "0 + C(sessioncode)"}

    md = MixedLM(
        endog=df_model["cont"],
        exog=df_model[["intercept", "losses"]],
        groups=df_model["id"],
        vc_formula=vc,
    )

    mdf = md.fit(reml=False)

    # Print summary
    print(mdf.summary())

    # Save key results to a csv for downstream comparison
    result_path = Path("/app/data/replication_results.csv")
    coefs = mdf.params
    pvals = mdf.pvalues

    out = pd.DataFrame({"coef": coefs, "pval": pvals})
    out.to_csv(result_path, index=True)
    print(f"Results saved to {result_path}
... (truncated)

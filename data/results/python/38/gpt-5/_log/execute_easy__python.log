import os
import json
import pandas as pd
import numpy as np
import statsmodels.api as sm

DATA_FILE = "/app/data/McCarter_OrgBehavior_2010_pILK data CLEAN.csv"
OUT_TEXT = "/app/data/mccarter_pILK_mixedlm_results.txt"
OUT_JSON = "/app/data/mccarter_pILK_mixedlm_results.json"


def load_data(path: str) -> pd.DataFrame:
    df = pd.read_csv(path)
    # Standardize column names just in case
    # Keep original names for mapping used below
    return df


def prepare_df(df: pd.DataFrame) -> pd.DataFrame:
    required_cols = [
        "cont", "losses", "id", "sessioncode",
    ]
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"Required columns missing from dataset: {missing}")

    # Coerce types
    df = df.copy()
    df["id"] = pd.to_numeric(df["id"], errors="coerce")
    df["losses"] = pd.to_numeric(df["losses"], errors="coerce").astype("Int64")
    df["cont"] = pd.to_numeric(df["cont"], errors="coerce")
    df["sessioncode"] = df["sessioncode"].astype(str)

    # Drop rows with missing key vars
    df = df.dropna(subset=["id", "losses", "cont", "sessioncode"]).copy()

    # Ensure categorical coding for variance component
    df["sessioncode_cat"] = df["sessioncode"].astype("category")
    return df


def fit_mixedlm(df: pd.DataFrame, y: str, x: str = "losses"):
    # Mixed model with random intercepts for participant (id) and session (sessioncode)
    # Use variance components for session-level random intercepts
    formula = f"{y} ~ {x}"
    # groups -> participant id; session variance components via vc_formula
    model = sm.MixedLM.from_formula(
        formula,
        groups=df["id"],
        vc_formula={"session": "0 + C(sessioncode)"},
        re_formula="1",
        data=df,
    )
    # Use ML (REML=False) for comparability
    result = model.fit(method="lbfgs", reml=False, maxiter=200, disp=False)
    return result



rm(list=ls())
library(data.table) # for fast data loading
library(sandwich)   # for robust variance estimators
# miceadds removed; using sandwich::vcovCL for clustered SEs

# Per container policy, read/write under /app/data# Per container policy, prefer /app/data; fallback to mounted replication_data
if (dir.exists('/app/data')) {
  setwd('/app/data')
} else if (dir.exists('/workspace/replication_data')) {
  setwd('/workspace/replication_data')
} else {
  stop('Data directory not found: expected /app/data or /workspace/replication_data')
}

# Load dataset# Load dataset
FinDT <- as.data.frame(read.csv('Estimation Data - Pitts (126zz).csv'))

# Listwise deletion on variables used in model (consistent with na.omit intent)
vars_used <- c('LeavingAgency','JobSat','Over40','NonMinority','SatPay','SatAdvan','PerfCul','Empowerment','RelSup','Relcow','Over40xSatAdvan','Agency')
FinDT <- FinDT[complete.cases(FinDT[, vars_used]), ]

# Estimation using clustered logistic regression (clustered by Agency)# Fit logistic regression (binomial link)
myLogit <- glm(
  formula = LeavingAgency ~ JobSat + Over40 + NonMinority + SatPay + SatAdvan + PerfCul + Empowerment + RelSup + Relcow + Over40xSatAdvan,
  data = FinDT,
  family = binomial(link = 'logit')
)

# Cluster-robust variance-covariance matrix by Agency
cl <- as.factor(FinDT$Agency)
V_cl <- sandwich::vcovCL(myLogit, cluster = cl)

# Compute robust coefficient table
coefs <- coef(myLogit)
se <- sqrt(diag(V_cl))
z <- coefs / se
p <- 2 * pnorm(abs(z), lower.tail = FALSE)
res_tab <- data.frame(Estimate = coefs, Robust_SE = se, z = z, p_value = p, row.names = names(coefs))

# Output results to console and file under /app/data# Output results to console and file under /app/data
res_file <- '/app/data/replication_results_pitts_126zz.txt'
sink(res_file)
print(summary(myLogit))
sink()
print(summary(myLogit))


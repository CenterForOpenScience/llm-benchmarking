library("lmtest")
library("sandwich")
set.seed(2020)

## Uses the output from the data build.

main <- functionmain <- function(mode = "test", drop_wave_7 = TRUE){
  # Ensure output directory exists
  if (!dir.exists("output")) dir.create("output")
  
  # Load data (path relative to repo root)
  data <- read.csv("replication_data/data.csv")
  
  # Optionally drop observations from survey wave 7
  if (drop_wave_7) data <- data[!(data$wave == 7), ]
  drop <- ifelse(drop_wave_7, "drop_7", "keep_7")
  
  # In test mode shuffle each numeric column independently to break real correlations
  if (mode == "test"){
    for (i in 3:ncol(data)){
      data[, i] <- sample(data[, i])
    }
  }
  
  # Baseline "Long" model mirroring original paper, with HC1 robust SE
  model <- lm(gov_consumption ~ sd_gov + mean_gov +
                africa + laam + asiae +
                col_uka + col_espa + col_otha +
                federal + oecd +
                log_gdp_per_capita + trade_share + age_15_64 + age_65_plus, 
              data = data)
  out <- coeftest(model, vcov = vcovHC(model, type = "HC1"))
  
  # Append observation count and R-squared for readability
  out <- rbind(out, c(length(model$residuals), "", "", ""))
  out <- rbind(out, c(summary(model)$r.squared, "", "", ""))
  rownames(out) <- c(rownames(out)[-c((nrow(out)-1):nrow(out))], "Obs.", "R-squared")
  
  # Write table to disk
  write.table(out, file = sprintf("output/%s_%s.txt", mode, drop))
}write.table(out, file = sprintf("output/%s_%s.txt", mode, drop))
}

# Test analysis code

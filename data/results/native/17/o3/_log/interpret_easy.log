library(lmtest)
library(sandwich)
set.seed(2020)

# Utility to ensure an output directory exists
ensure_dir <- function(path){
  if (!dir.exists(path)) dir.create(path, recursive = TRUE)
}

# Helper that encodes the long specification
run_model <- function(df){
  lm(gov_consumption ~ sd_gov + mean_gov +
       africa + laam + asiae +
       col_uka + col_espa + col_otha +
       federal + oecd +
       log_gdp_per_capita + trade_share + age_15_64 + age_65_plus,
     data = df)
}

main <- function(mode = "test", drop_wave_7 = TRUE){
  ensure_dir("output")

  # Load input data (path relative to repository root)
  df <- read.csv("replication_data/data.csv")

  # Optional sample restriction
  if (drop_wave_7) df <- df[df$wave != 7, ]
  drop_tag <- ifelse(drop_wave_7, "drop_7", "keep_7")

  # Test mode shuffles data to break real structure (sanity check)
  if (mode == "test"){
    for (i in 3:ncol(df)){
      df[, i] <- sample(df[, i])
    }
  }

  # Fit model and obtain HC1 robust SEs
  model <- run_model(df)
  ct <- lmtest::coeftest(model, vcov = sandwich::vcovHC(model, type = "HC1"))

  # Append observation count and R-squared
  ct <- rbind(ct, c(length(model$residuals), "", "", ""))
  ct <- rbind(ct, c(summary(model)$r.squared, "", "", ""))
  rownames(ct)[(nrow(ct)-1):nrow(ct)] <- c("Obs.", "R-squared")

  # Export results
  write.table(ct, file = sprintf("output/%s_%s.txt", mode, drop_tag), quote = FALSE)
}

# Execute predefined runs
main("test", TRUE)
main("test", FALSE)
main("real", TRUE)
main("real", FALSE)


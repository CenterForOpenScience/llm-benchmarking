# Popper Replication Driver Script
# This script loads the replication datasets, fits the focal SEM (Model 1)
# and saves key results (standardised beta for OPEN -> LEAD and model fit)
# to /app/data/results.txt (or a fallback path) so that the orchestrator
# can capture outputs.

suppressPackageStartupMessages({
  library(lavaan)
  library(psych)
  library(dplyr)
})

# Helper to locate a file across several candidate paths
locate_file <- function(fname) {
  candidates <- c(
    file.path("/app/data", fname),
    file.path("/workspace/data", fname),
    file.path("/workspace/replication_data/Popper Replication Data Files", fname),
    file.path("replication_data/Popper Replication Data Files", fname),
    file.path("Popper Replication Data Files", fname),
    fname
  )
  for (p in candidates) {
    if (file.exists(p)) return(p)
  }
  stop(paste("File", fname, "not found in any candidate locations."))
}


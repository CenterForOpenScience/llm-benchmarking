# Replication analysis for Yang et al. (2013) focal claim: Lottery vs Gift framing reduces WTP
# This script is adapted to run in the SCORE container with data under /app/data
# It fixes path issues and minor coding problems in the provided Script.R

# Dependencies
suppressPackageStartupMessages({
  library(psych)        # describeBy
  library(effsize)      # cohen.d
})

# I/O paths
DATA_PATH <- "/app/data/Data_Cleaned_22102020.csv"
OUTPUT_SUBSET <- "/app/data/dataS.csv"

# Load data (robust to blanks)# Load data (robust to blanks and encodings)
# Try multiple encodings and as a fallback, sanitize with iconv
safe_read_csv <- function(path) {safe_read_csv <- function(path) {
  encs <- c("UTF-8-BOM", "UTF-8", "latin1", "windows-1252")
  for (enc in encs) {
    out <- try(read.csv(path, header = TRUE, na.strings = c("", "NA", " "), fileEncoding = enc), silent = TRUE)
    if (!inherits(out, "try-error") && is.data.frame(out) && ncol(out) > 0 && nrow(out) > 0) {
      return(out)
    }
  }
  # Fallback: read lines and sanitize to UTF-8
  con <- file(path, open = "rb")
  raw_bytes <- readBin(con, what = "raw", n = file.info(path)$size)
  close(con)
  # Strip UTF-8 BOM if present
  if (length(raw_bytes) >= 3 && all(raw_bytes[1:3] == as.raw(c(0xEF, 0xBB, 0xBF)))) {
    raw_bytes <- raw_bytes[-c(1:3)]
  }
  txt <- rawToChar(raw_bytes)
  # Try converting to UTF-8 safely
  txt_utf8 <- iconv(txt, from = "", to = "UTF-8", sub = "")
  # Ensure lines are separated consistently
  txt_utf8 <- gsub("\r\n?", "\n", txt_utf8)
  out <- read.csv(text = txt_utf8, header = TRUE, na.strings = c("", "NA", " "))
  if (!is.data.frame(out) || nrow(out) == 0) stop("Parsed CSV has no rows after sanitization")
  return(out)
}

raw <- tryCatch({raw <- tryCatch({
  safe_read_csv(DATA_PATH)
}, error = function(e) {
  stop(paste0("Failed to read data from ", DATA_PATH, ": ", e$message))
})


# Replication analysis for Yang et al. (2013) focal claim: Lottery vs Gift framing reduces WTP
# This script is adapted to run in the SCORE container with data under /app/data
# It fixes path issues and minor coding problems in the provided Script.R

# Dependencies
suppressPackageStartupMessages({
  library(psych)        # describeBy
  library(effsize)      # cohen.d
})

# I/O paths
DATA_PATH <- "/app/data/Data_Cleaned_22102020.csv"
OUTPUT_SUBSET <- "/app/data/dataS.csv"

# Load data (robust to blanks)
# Treat common blanks and explicit "NA" as missing
raw <- tryCatch({
  read.csv(DATA_PATH, header = TRUE, na.strings = c("", "NA", " "))
}, error = function(e) {
  stop(paste0("Failed to read data from ", DATA_PATH, ": ", e$message))
})

# Helper: coerce numeric columns if they contain stray symbols
clean_numeric <- function(x) {
  if (is.numeric(x)) return(x)
  as.numeric(gsub("[^0-9.\-]", "", as.character(x)))
}

# Clean coded WTP variables (prefer coded versions if available)
raw$Lot_WTPc <- clean_numeric(raw$Lot_WTPc)
raw$Gift_WTPc <- clean_numeric(raw$Gift_WTPc)

# Some datasets may have only one of the WTPc vars present as numeric
# Create condition variable based on which comprehension check exists
lot_chk <- clean_numeric(raw$Lot_check)
gft_chk <- clean_numeric(raw$Gift_check)

Cond <- rep(NA_integer_, nrow(raw))
Cond[!is.na(lot_chk) & is.na(gft_chk)] <- 0L   # lottery condition
Cond[is.na(lot_chk) & !is.na(gft_chk)] <- 1L   # gift condition
# In rare cases where both present, prioritize the non-missing coded WTP
both <- which(!is.na(lot_chk) & !is.na(gft_chk))
if (length(both) > 0) {
  use_lot <- which(!is.na(raw$Lot_WTPc[both]) & is.na(raw$Gift_WTPc[both]))
  use_gft <- which(is.na(raw$Lot_WTPc[both]) & !is.na(raw$Gift_WTPc[both]))
  if (length(use_lot) > 0) Cond[both[use_lot]] <- 0L
  if (length(use_gft) > 0) Cond[both[use_gft]] <- 1L
}
raw$Cond <- factor(Cond, levels = c(0, 1), labels = c("lottery", "gift"))


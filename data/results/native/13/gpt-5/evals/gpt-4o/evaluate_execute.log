             stfeco_rev + hincfel + stfhlth_rev + stfedu_rev +
             vote_gov + vote_frparty + lrscale + hhinc_std + agea + educ + female + 
             vote_share_fr + socexp + lt_imm_cntry + wgi + gdppc + unemp + (1 | cntry),
           weights = pspwght,
           data = data_clean_5pct)

summary(m1)



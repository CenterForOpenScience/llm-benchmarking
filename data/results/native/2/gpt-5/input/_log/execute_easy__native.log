# Import data set from GitHub
# install.packages("readr")
 # Data are provided locally in /app/data. Do not download from internet.
 dat_seaton <- readRDS("/workspace/replication_data/PISA2012.replication.RDS")
 
#install.packages("dplyr")
 library(dplyr)
 dat_seaton$uniqueSchoolID <- paste0(dat_seaton$SCHOOLID, "|", dat_seaton$CNT) #this creates a *unique* school ID

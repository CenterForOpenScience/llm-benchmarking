#                           format = "%m/%d/%Y %H:%M", 
#                           tz = "America/New_York"))

#else
DF <- subset(DF, 
             as.POSIXct(DF$created, tz = "America/New_York") > 
               as.POSIXct("2021-01-18 15:39:38", tz = "America/New_York"))
```


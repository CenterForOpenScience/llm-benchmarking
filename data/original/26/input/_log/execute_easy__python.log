import os
import pandas as pd
import numpy as np

# All IO paths must be under /app/data per policy
RAW_BASE = "/app/data/replication_data/Raw data"
OUT_PATH = "/app/data/replication_data/k17_processed_data.csv"

# Helper to parse dates safely

def parse_date(s):
    try:
        return pd.to_datetime(s)
    except Exception:
        return pd.NaT


def main():
    # Load raw
    t1 = pd.read_csv(os.path.join(RAW_BASE, 'k17_t1_data.csv'))
    t2 = pd.read_csv(os.path.join(RAW_BASE, 'k17_t2_data.csv'))
    t3 = pd.read_csv(os.path.join(RAW_BASE, 'k17_t3_data.csv'))

